{
  "name": "aizo",
  "version": "1.0.0",
  "private": true,
  "description": "Aizo — AI Proposal Generator. Fill a form, get a winning proposal in seconds.",
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "dev": "concurrently -n server,client -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
    "concurrently": "^9.1.0"
  }
}
